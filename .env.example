# Fichier .env à créer à la racine (côté docker-compose.yml), jamais commité.
# Docker Compose lit ce fichier pour substituer les ${VAR} dans docker-compose.yml.
#
# IMPORTANT : les $ dans le hash bcrypt doivent être doublés ($$) ici,
# car Docker Compose fait l'interpolation sur ce fichier.
# Le conteneur recevra la valeur correcte avec des $ simples.
#
# Pour générer un nouveau hash :
#   cd 3gsolutionapp && node scripts/generate-superadmin-hash.mjs monMotDePasse

SUPERADMIN_EMAIL=leo@mail.com
SUPERADMIN_PASSWORD_HASH=$$2a$$10$$uUpTVN1D3h/miTqdqP6QqO0MLNbiWmvip9g.2H3LISNRWx/Wf4oli
SUPERADMIN_JWT_SECRET=superadmin_jwt_secret_change_in_prod
